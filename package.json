{
  "name": "timla-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "npm run dev --workspace timla-frontend",
    "build:frontend": "npm run build --workspace timla-frontend",
    "lint": "eslint frontend",
    "lint:fix": "eslint frontend --fix",
    "typecheck:frontend": "npm run typecheck --workspace timla-frontend",
    "precommit": "npm run lint && npm run typecheck:frontend && npm run build:frontend"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.55.0"
  }
}
