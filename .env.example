# Backend dev config. Copy to `.env` (gitignored) — app/_env.py auto-loads it.
# Real environment variables (inline, docker-compose, CI) override anything here.
#
# Note: the frontend's VITE_CLERK_PUBLISHABLE_KEY lives in frontend/.env.local
# (Vite reads it at build time), not here — same key value, different file.

# Clerk publishable key. Backend verifies session JWTs against it; optional in
# dev (TIMLA_ENV=dev), required otherwise. Same value as the frontend's VITE_ one.
CLERK_PUBLISHABLE_KEY=

# Postgres. Dev default targets the docker-compose instance on host port 5433.
DATABASE_URL=postgresql://timla:timla@localhost:5433/timla

# dev | prod. dev relaxes the fail-loud guards (SECRET_KEY, Clerk key).
TIMLA_ENV=dev

# Required when TIMLA_ENV is not dev.
# SECRET_KEY=
