# Production operator config. Copy to `.env.prod` (gitignored) and fill in.
#
# This file is ONLY read by docker compose for variable interpolation, via:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml ...
# It is never copied into or mounted in the image; everything the app sees
# arrives as real environment variables set by the compose file. It is
# unrelated to the dev `.env` that app/_env.py auto-loads for host-run
# backends.
#
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Postgres superuser password for the bundled postgres service. SECRET.
# Interpolated into DATABASE_URL, so it must be URI-safe (no characters that
# need percent-encoding) — the hex generator above satisfies this.
POSTGRES_PASSWORD=

# Flask session signing key. SECRET. Must be stable across restarts and
# identical for all gunicorn workers (the app refuses to start without it
# when TIMLA_ENV=prod).
SECRET_KEY=

# Clerk publishable key (pk_live_... for a production Clerk instance).
# Not secret, but deployment-specific. This single value feeds BOTH the
# frontend build (baked into the bundle by Vite at image build time) and the
# backend's JWT verification — set it before `docker compose ... build`.
CLERK_PUBLISHABLE_KEY=

# Optional: host address:port the app is published on. Default is loopback
# (127.0.0.1:8899) so only a local reverse proxy can reach it — recommended.
# WARNING: binding to a public interface without network-level restrictions
# lets clients spoof X-Forwarded-* headers (ProxyFix trusts one hop) and
# bypass the /svar rate limiter. See docs/deployment.md before changing.
# TIMLA_BIND=127.0.0.1:8899
